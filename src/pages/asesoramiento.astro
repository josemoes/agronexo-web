---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanda from '../components/HeroBanda.astro';
---

<BaseLayout
  title="Asesoramiento — AgroNexo Granada"
  description="Estudio a medida para tu finca: diagnóstico in-situ, plan de optimización y seguimiento continuo para el olivar y almendro de Granada."
>

  <!-- Hero banda -->
  <HeroBanda
    image="/images/hero/asesoramiento.webp"
    eyebrow="AgroNexo Advisory"
    title="Asesoramiento a medida"
    subtitle="Diagnóstico in-situ, plan de optimización y seguimiento continuo para tu olivar."
  />

  <!-- Placeholder -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-agronexo-warm">Contenido en construcción.</p>
    </div>
  </section>

</BaseLayout>
