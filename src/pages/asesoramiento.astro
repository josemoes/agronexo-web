---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Asesoramiento — AgroNexo Granada"
  description="Estudio a medida para tu finca: diagnóstico in-situ, plan de optimización y seguimiento continuo para el olivar y almendro de Granada."
>

  <!-- Hero banda -->
  <section
    class="relative flex items-end min-h-[45vh] bg-agronexo-dark bg-cover bg-center"
    style="background-image: url('/images/hero/asesoramiento.webp')"
  >
    <div class="absolute inset-0 bg-agronexo-dark/60"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 md:pb-16 w-full">
      <p class="font-display text-xs font-semibold tracking-widest text-agronexo-olive uppercase mb-3">
        AgroNexo Advisory
      </p>
      <h1 class="font-display font-bold text-4xl md:text-5xl text-white leading-tight">
        Asesoramiento
      </h1>
    </div>
  </section>

  <!-- Placeholder -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-agronexo-warm">Contenido en construcción.</p>
    </div>
  </section>

</BaseLayout>
