---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanda from '../components/HeroBanda.astro';
---

<BaseLayout
  title="Contacto — AgroNexo Granada"
  description="Contacta con AgroNexo Granada. Cuéntanos qué necesitas y te respondemos en menos de 24 horas."
>

  <!-- ── 1. HERO BANDA ───────────────────────────────────────────────────── -->
  <HeroBanda
    image="/images/hero/asesoramiento.webp"
    eyebrow="AgroNexo Granada"
    title="Hablemos de tu olivar"
    subtitle="Cuéntanos qué necesitas y te respondemos en menos de 24 horas."
    minHeight="min-h-[40vh]"
  />

  <!-- ── 2. FORMULARIO + DATOS ──────────────────────────────────────────── -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20">

        <!-- LEFT: Formulario -->
        <div class="lg:col-span-3">
          <p class="font-display text-xs font-semibold tracking-widest text-agronexo-olive uppercase mb-4">
            Escríbenos
          </p>
          <h2 class="font-display font-bold text-2xl md:text-3xl text-agronexo-dark mb-8 leading-snug">
            ¿En qué podemos ayudarte?
          </h2>

          <div role="form" aria-label="Formulario de contacto" class="flex flex-col gap-5">

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label for="nombre" class="font-display font-semibold text-xs tracking-wide text-agronexo-dark">
                  Nombre completo
                </label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Manuel Ortega"
                  class="font-body text-sm text-agronexo-text border border-agronexo-warm/40 rounded-md px-4 py-2.5 focus:outline-none focus:border-agronexo-olive placeholder:text-agronexo-warm/60"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="email" class="font-display font-semibold text-xs tracking-wide text-agronexo-dark">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="manuel@example.com"
                  class="font-body text-sm text-agronexo-text border border-agronexo-warm/40 rounded-md px-4 py-2.5 focus:outline-none focus:border-agronexo-olive placeholder:text-agronexo-warm/60"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5">
                <label for="telefono" class="font-display font-semibold text-xs tracking-wide text-agronexo-dark">
                  Teléfono
                  <span class="font-body font-normal text-agronexo-warm">(opcional)</span>
                </label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  placeholder="600 000 000"
                  class="font-body text-sm text-agronexo-text border border-agronexo-warm/40 rounded-md px-4 py-2.5 focus:outline-none focus:border-agronexo-olive placeholder:text-agronexo-warm/60"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="tipo" class="font-display font-semibold text-xs tracking-wide text-agronexo-dark">
                  Tipo de consulta
                </label>
                <select
                  id="tipo"
                  name="tipo"
                  class="font-body text-sm text-agronexo-text border border-agronexo-warm/40 rounded-md px-4 py-2.5 focus:outline-none focus:border-agronexo-olive bg-white"
                >
                  <option value="">Selecciona una opción</option>
                  <option value="productos">Información sobre productos</option>
                  <option value="asesoramiento">Asesoramiento técnico</option>
                  <option value="fincas">Gestión de finca</option>
                  <option value="otro">Otra consulta</option>
                </select>
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="mensaje" class="font-display font-semibold text-xs tracking-wide text-agronexo-dark">
                Mensaje
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                placeholder="Cuéntanos cómo es tu finca y qué necesitas…"
                class="font-body text-sm text-agronexo-text border border-agronexo-warm/40 rounded-md px-4 py-2.5 focus:outline-none focus:border-agronexo-olive placeholder:text-agronexo-warm/60 resize-none"
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="rgpd"
                name="rgpd"
                class="mt-0.5 shrink-0 accent-agronexo-olive"
              />
              <label for="rgpd" class="font-body text-xs text-agronexo-text leading-relaxed">
                Acepto la <a href="/legal/privacidad" class="underline hover:text-agronexo-olive transition-colors duration-200">política de privacidad</a> y el tratamiento de mis datos para gestionar mi consulta.
              </label>
            </div>

            <button
              type="button"
              class="self-start font-display font-semibold text-sm tracking-wide px-8 py-3 bg-agronexo-olive text-white rounded-md hover:bg-agronexo-dark transition-colors duration-200"
            >
              Enviar mensaje
            </button>

            <p class="font-body text-xs text-agronexo-warm">
              *Formulario decorativo — prototipo TFM. Ningún dato es enviado.
            </p>

          </div>
        </div>

        <!-- RIGHT: Datos de contacto -->
        <div class="lg:col-span-2 flex flex-col gap-8">
          <div>
            <p class="font-display text-xs font-semibold tracking-widest text-agronexo-olive uppercase mb-4">
              Datos de contacto
            </p>
            <h2 class="font-display font-bold text-2xl md:text-3xl text-agronexo-dark mb-2 leading-snug">
              Estamos en Granada
            </h2>
            <p class="font-body text-sm text-agronexo-warm mb-6">
              Atendemos olivares en toda la provincia.
            </p>
          </div>

          <ul class="flex flex-col gap-6">
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-md bg-agronexo-olive/10 flex items-center justify-center text-agronexo-olive shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-warm mb-1">Email</p>
                <p class="font-body text-sm text-agronexo-text">contacto@agronexo.es</p>
              </div>
            </li>

            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-md bg-agronexo-olive/10 flex items-center justify-center text-agronexo-olive shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-warm mb-1">Teléfono</p>
                <p class="font-body text-sm text-agronexo-text">+34 958 000 000</p>
              </div>
            </li>

            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-md bg-agronexo-olive/10 flex items-center justify-center text-agronexo-olive shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-warm mb-1">Ubicación</p>
                <p class="font-body text-sm text-agronexo-text">Granada, Andalucía</p>
                <p class="font-body text-xs text-agronexo-warm mt-0.5">Atendemos toda la provincia</p>
              </div>
            </li>
          </ul>

          <!-- Redes sociales -->
          <div class="pt-4 border-t border-agronexo-warm/20">
            <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-warm mb-4">
              Síguenos
            </p>
            <div class="flex items-center gap-3">
              <a
                href="#"
                rel="noopener noreferrer"
                aria-label="AgroNexo en Instagram"
                class="w-10 h-10 rounded-md bg-agronexo-olive/10 flex items-center justify-center text-agronexo-olive hover:bg-agronexo-olive hover:text-white transition-colors duration-200"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </a>
              <a
                href="#"
                rel="noopener noreferrer"
                aria-label="AgroNexo en LinkedIn"
                class="w-10 h-10 rounded-md bg-agronexo-olive/10 flex items-center justify-center text-agronexo-olive hover:bg-agronexo-olive hover:text-white transition-colors duration-200"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <a
                href="#"
                rel="noopener noreferrer"
                aria-label="AgroNexo en X"
                class="w-10 h-10 rounded-md bg-agronexo-olive/10 flex items-center justify-center text-agronexo-olive hover:bg-agronexo-olive hover:text-white transition-colors duration-200"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
