---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanda from '../components/HeroBanda.astro';
---

<BaseLayout
  title="Fincas — AgroNexo Granada"
  description="Activación de tierras infrautilizadas con un paquete completo: arrendamiento, asesoramiento y gestión integral del olivar y almendro."
>

  <!-- Hero banda -->
  <HeroBanda
    image="/images/hero/fincas.webp"
    eyebrow="AgroNexo Fincas"
    title="Tu finca, activada"
    subtitle="Tierras sin gestionar convertidas en olivares rentables. Nosotros nos encargamos de todo."
  />

  <!-- Placeholder -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-agronexo-warm">Contenido en construcción.</p>
    </div>
  </section>

</BaseLayout>
