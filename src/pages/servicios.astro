---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanda from '../components/HeroBanda.astro';
---

<BaseLayout
  title="Servicios — AgroNexo Granada"
  description="Servicios de asesoramiento agrícola: visita técnica, análisis de suelo, poda y proyectos integrales SCAN, DESIGN, DEPLOY, CONTROL y FUNDING."
>

  <!-- Hero banda -->
  <HeroBanda
    image="/images/hero/servicios.webp"
    eyebrow="AgroNexo Advisory"
    title="Servicios para tu finca"
    subtitle="Desde una visita técnica puntual hasta un proyecto integral de optimización."
  />

  <!-- Placeholder -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body text-agronexo-warm">Contenido en construcción.</p>
    </div>
  </section>

</BaseLayout>
