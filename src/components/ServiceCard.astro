---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  dataPoints: string[];
  ctaLabel: string;
  ctaSecondary?: { label: string; href: string };
}

const { eyebrow, title, description, dataPoints, ctaLabel, ctaSecondary } = Astro.props;
---

<div class="flex flex-col gap-5 bg-white rounded-lg p-8 border border-agronexo-warm/20 hover:border-agronexo-olive/40 transition-colors duration-200">
  <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-olive">
    {eyebrow}
  </p>
  <h3 class="font-display font-bold text-xl text-agronexo-dark leading-snug">
    {title}
  </h3>
  <p class="font-body text-sm text-agronexo-text leading-relaxed flex-1">
    {description}
  </p>
  <ul class="flex flex-col gap-1.5">
    {dataPoints.map((point) => (
      <li class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-agronexo-olive shrink-0" aria-hidden="true"></span>
        <span class="font-body text-xs text-agronexo-warm">{point}</span>
      </li>
    ))}
  </ul>
  <div class="flex flex-col gap-2 pt-1">
    <a
      href="/contacto"
      class="font-display font-semibold text-sm tracking-wide px-5 py-3 bg-agronexo-dark text-white rounded-md hover:bg-agronexo-olive transition-colors duration-200 text-center"
    >
      {ctaLabel}
    </a>
    {ctaSecondary && (
      <a
        href={ctaSecondary.href}
        class="flex items-center justify-center gap-2 font-display font-semibold text-sm tracking-wide px-5 py-3 border border-agronexo-dark text-agronexo-dark rounded-md hover:bg-agronexo-dark hover:text-white transition-colors duration-200"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        {ctaSecondary.label}
      </a>
    )}
  </div>
</div>
