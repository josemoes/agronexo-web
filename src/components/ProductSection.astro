---
const {
  name,
  badge,
  description,
  benefits,
  specs,
  price,
  image,
  imageAlt,
  imageLeft,
  bgClass,
} = Astro.props;

const slug = name
  .toLowerCase()
  .normalize('NFD')
  .replace(/[̀-ͯ]/g, '')
  .replace(/\s+/g, '-');
---

<section id={`producto-${slug}`} class={bgClass}>
  <div class={`flex flex-col ${imageLeft ? 'md:flex-row' : 'md:flex-row-reverse'}`}>

    <!-- Image column -->
    <div class="w-full md:w-1/2 shrink-0 aspect-[5/4] md:aspect-auto">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>

    <!-- Content column -->
    <div class="w-full md:w-1/2 flex items-center justify-center py-12 md:py-16">
      <div class="w-full max-w-lg px-6 md:px-10 lg:px-14 flex flex-col gap-5">

        <!-- Badge -->
        <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-olive">
          {badge}
        </p>

        <!-- Name -->
        <h2 class="font-display font-bold text-3xl md:text-4xl text-agronexo-dark leading-tight">
          {name}
        </h2>

        <!-- Description -->
        <p class="font-body text-base text-agronexo-text leading-relaxed">
          {description}
        </p>

        <!-- Benefits -->
        <ul class="flex flex-col gap-2.5">
          {benefits.map((benefit: string) => (
            <li class="flex items-start gap-3">
              <svg
                class="w-4 h-4 shrink-0 mt-0.5 text-agronexo-olive"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="font-body text-sm text-agronexo-text">{benefit}</span>
            </li>
          ))}
        </ul>

        <!-- Specs -->
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 bg-agronexo-warm/10 rounded-lg px-4 py-3">
          <span class="font-body text-xs text-agronexo-text">
            <span class="font-medium text-agronexo-dark">Presentación:</span> {specs.presentacion}
          </span>
          <span class="text-agronexo-warm/40 text-xs">·</span>
          <span class="font-body text-xs text-agronexo-text">
            <span class="font-medium text-agronexo-dark">Aplicación:</span> {specs.aplicacion}
          </span>
          <span class="text-agronexo-warm/40 text-xs">·</span>
          <span class="font-body text-xs text-agronexo-text">
            <span class="font-medium text-agronexo-dark">Disponibilidad:</span> {specs.disponibilidad}
          </span>
        </div>

        <!-- Price -->
        <div>
          <p class="font-display font-bold text-2xl text-agronexo-dark">{price}</p>
          <p class="font-body text-xs text-agronexo-warm mt-1">
            *precio orientativo, consulta en cooperativa
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 pt-1">
          <a
            href="#"
            class="font-display font-semibold text-sm tracking-wide px-6 py-3 bg-agronexo-dark text-white rounded-md hover:bg-agronexo-olive transition-colors duration-200 text-center"
          >
            Añadir al carrito
          </a>
          <a
            href={`#producto-${slug}`}
            class="font-display font-semibold text-sm tracking-wide px-6 py-3 border border-agronexo-dark text-agronexo-dark rounded-md hover:bg-agronexo-dark hover:text-white transition-colors duration-200 text-center"
          >
            Ver más detalles →
          </a>
        </div>

      </div>
    </div>

  </div>
</section>
