---
interface Props {
  image: string;
  imageAlt: string;
  eyebrow: string;
  quote: string;
  authorName: string;
  authorRole: string;
  stats: { label: string; value: string }[];
}

const { image, imageAlt, eyebrow, quote, authorName, authorRole, stats } = Astro.props;
---

<section class="bg-agronexo-dark">
  <div class="flex flex-col md:flex-row">

    <!-- Image -->
    <div class="w-full md:w-1/2 shrink-0 aspect-[5/4] md:aspect-auto">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover opacity-80"
        loading="lazy"
      />
    </div>

    <!-- Content -->
    <div class="w-full md:w-1/2 flex items-center justify-center py-12 md:py-16">
      <div class="w-full max-w-lg px-6 md:px-10 lg:px-14 flex flex-col gap-6">

        <p class="font-display font-semibold text-xs tracking-widest uppercase text-agronexo-olive">
          {eyebrow}
        </p>

        <blockquote class="flex flex-col gap-4">
          <p class="font-display font-semibold text-xl md:text-2xl text-white leading-snug">
            "{quote}"
          </p>
          <footer>
            <p class="font-body text-sm font-medium text-white">{authorName}</p>
            <p class="font-body text-xs text-agronexo-warm">{authorRole}</p>
          </footer>
        </blockquote>

        <div class="grid grid-cols-2 gap-x-6 gap-y-4 pt-4 border-t border-white/10">
          {stats.map(({ label, value }) => (
            <div class="flex flex-col gap-0.5">
              <span class="font-body text-xs text-agronexo-warm">{label}</span>
              <span class="font-display font-semibold text-sm text-white">{value}</span>
            </div>
          ))}
        </div>

      </div>
    </div>

  </div>
</section>
